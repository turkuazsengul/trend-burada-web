# This project mixes old (react-scripts 3.4.1, axios 0.19.x, primereact 10) with newer
# packages (@tanstack/react-query 4). npm 7+ enforces peerDependencies strictly which makes
# install fail on harmless conflicts — e.g. react-query 4.44 declares react-native as a
# peerOptional, and npm tries to reconcile its @types/react@19 hint against primereact's
# @types/react@17||18, even though we never install react-native.
#
# `legacy-peer-deps=true` switches npm back to the npm 6 behaviour: install what each
# package directly asks for and skip transitive peer reconciliation. Safe here because
# we don't have any of the conflicting transitive packages (no react-native, no React 19).
#
# Revisit when react-scripts is upgraded to v5 and PrimeReact/React are bumped — at that
# point regular peer resolution should work and this flag can be dropped.
legacy-peer-deps=true
